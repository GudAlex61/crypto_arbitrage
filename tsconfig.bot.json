{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "noEmit": true,  // tsx работает без компиляции, но можно оставить noEmit: true
    "types": ["node"]
  },
  "include": ["src/bot/**/*.ts"],
  "exclude": ["node_modules"]
}