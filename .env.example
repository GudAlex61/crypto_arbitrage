# Dashboard / server
PORT=3001

# Exchange selection. Empty = all supported exchanges.
# ENABLED_EXCHANGES=Binance,Bybit,OKX,Gate,KuCoin,MEXC,Bitget

# Arbitrage thresholds
MIN_NET_PROFIT_PCT=0
MAX_NET_PROFIT_PCT=25
MAX_PRICE_AGE_MS=45000
INITIAL_DELAY_MS=10000
PRICE_UPDATE_INTERVAL=5000
REST_REQUEST_TIMEOUT_MS=8000

# Order-book execution check. Bot recalculates opportunities by VWAP using this USDT size.
ORDERBOOK_ENABLED=true
ORDERBOOK_TRADE_AMOUNT_USDT=100
ORDERBOOK_DEPTH_LIMIT=50
ORDERBOOK_VERIFICATION_LIMIT=15
ORDERBOOK_CONCURRENCY=8
ORDERBOOK_FETCH_TIMEOUT_MS=5000
# Set true only if you want spot withdrawal fees deducted from Net %.
INCLUDE_WITHDRAWAL_FEES=false

BLACKLIST=TST,NEIRO

# Redis. If Redis is unavailable, the bot now falls back to in-memory cooldowns.
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password

# Telegram is disabled by default. Enable only if you really need alerts.
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
